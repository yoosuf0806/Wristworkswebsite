# ─── Site ────────────────────────────────────────────────────────────────
# Public site URL, used for canonical URLs, sitemap, and Open Graph tags
NEXT_PUBLIC_SITE_URL=https://wristworks.lk

# ─── Supabase ────────────────────────────────────────────────────────────
# Project URL and anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Analytics & Search Console ──────────────────────────────────────────
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Search Console verification token (content of the meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=your-search-console-token

# ─── WhatsApp ────────────────────────────────────────────────────────────
# Business WhatsApp number in international format (digits only)
NEXT_PUBLIC_WHATSAPP_NUMBER=94770000000
# WhatsApp Cloud API token + verify token for the webhook
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ─── Admin ───────────────────────────────────────────────────────────────
# Simple shared password gating the admin dashboard (replace with real auth)
ADMIN_PASSWORD=change-me
